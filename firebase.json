{
  "hosting": {
    "public": "frontend/dist",
    "rewrites": [
      {
        "source": "/chat",
        "run": { "serviceId": "task-mesh", "region": "us-central1" }
      },
      {
        "source": "/tasks/**",
        "run": { "serviceId": "task-mesh", "region": "us-central1" }
      },
      {
        "source": "/notes/**",
        "run": { "serviceId": "task-mesh", "region": "us-central1" }
      },
      {
        "source": "/logs/**",
        "run": { "serviceId": "task-mesh", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  }
}
